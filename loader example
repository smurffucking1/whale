--// SERVICES -----------------------------------------------------------

local Players     = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local StarterGui  = game:GetService("StarterGui")

-- Optional: hide backpack CoreGui just to make the UI stand out
StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)

local LocalPlayer = Players.LocalPlayer

--// EXECUTOR FILE CONFIG ----------------------------------------------

local SAVE_FOLDER = "BoatSaves"               -- reuse same folder name
local CONFIG_FILE = SAVE_FOLDER .. "/gui_config.json"

local function ensureFolder()
    if not listfiles or not writefile then return end
    local ok = pcall(function()
        listfiles(SAVE_FOLDER)
    end)
    if not ok then
        pcall(function()
            writefile(SAVE_FOLDER .. "/.init", "init")
        end)
    end
end

ensureFolder()

local function saveGuiConfig(configTable)
    if not writefile then
        warn("[GUI Config] writefile not supported in this executor.")
        return
    end
    ensureFolder()
    local ok, json = pcall(function()
        return HttpService:JSONEncode(configTable)
    end)
    if not ok then
        warn("[GUI Config] JSON encode failed:", json)
        return
    end
    writefile(CONFIG_FILE, json)
end

local function loadGuiConfig()
    if not readfile then
        warn("[GUI Config] readfile not supported in this executor.")
        return nil
    end
    local ok, content = pcall(readfile, CONFIG_FILE)
    if not ok then
        return nil
    end
    local ok2, data = pcall(function()
        return HttpService:JSONDecode(content)
    end)
    if not ok2 then
        warn("[GUI Config] JSON decode failed:", data)
        return nil
    end
    return data
end

--// LOAD UI LIBRARY ----------------------------------------------------

local Library = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/smurffucking1/whale/refs/heads/main/lib3"
))()

--// CREATE WINDOW ------------------------------------------------------

local Window = Library:CreateWindow({
    Title        = "My New UI",
    DefaultTheme = "Dark",
    DestroyKey   = Enum.KeyCode.RightShift,
})

local MainTab     = Window:AddTab("Main")
local MiscTab     = Window:AddTab("Misc")
local SettingsTab = Window:AddTab("Settings")

--// CONFIG TABLE + APPLY TO WINDOW ------------------------------------

local CONFIG_NAME = "my_new_ui"

local config = loadGuiConfig() or {
    Godmode    = false,
    WalkSpeed  = 16,
    Width      = Window.Width,
    Height     = Window.Height,
    DockScale  = 1,
    AnchorX    = Window.AnchorOffsetX or 35,
    AnchorY    = Window.AnchorOffsetY or 0,
    ClockScale = 1,
}

config.Width      = math.clamp(config.Width      or Window.Width, 300, 900)
config.Height     = math.clamp(config.Height     or Window.Height, 220, 700)
config.DockScale  = math.clamp(config.DockScale  or 1,            0.6,  1.8)
config.AnchorX    = math.clamp(config.AnchorX    or 35,           0,    300)
config.AnchorY    = math.clamp(config.AnchorY    or 0,            -300, 300)
config.ClockScale = math.clamp(config.ClockScale or 1,            0.5,  2)

local function autosaveConfig()
    saveGuiConfig(config)
end

Window:SetAnchorMode("Left")
Window:SetWidth(config.Width)
Window:SetHeight(config.Height)
Window:SetAnchorOffsetX(config.AnchorX)
Window:SetAnchorOffsetY(config.AnchorY or 0)
Window:SetClockScale(config.ClockScale)
Window:SetDockScale(config.DockScale)

if Window.UpdateTabDock then
    Window:UpdateTabDock()
end

--// MAIN TAB ----------------------------------------------------------

MainTab:AddButton("Do something", function()
    print("[Main] Button clicked")
end)

MainTab:AddSlider("WalkSpeed", 16, 100, config.WalkSpeed, function(v)
    config.WalkSpeed = v
    print("[Main] WalkSpeed set to:", v)
    autosaveConfig()
end)

--// MISC TAB ----------------------------------------------------------

MiscTab:AddToggle("Godmode", config.Godmode, function(value)
    config.Godmode = value
    print("[Misc] Godmode:", value)
    autosaveConfig()
end)

MiscTab:AddButton("Next Mode", function()
    print("[Misc] Next Mode clicked")
end)

--// SETTINGS TAB ------------------------------------------------------

SettingsTab:AddKeybind("Toggle UI", Window.DestroyKey, function(newKey)
    Window:SetToggleKey(newKey)
    print("[Settings] Toggle key changed to:", newKey.Name)
end)

SettingsTab:AddDropdown("Theme", Library:GetThemes(), "Dark", function(themeName)
    Library:SetTheme(themeName)
    print("[Settings] Theme set to:", themeName)
    autosaveConfig()
end)

SettingsTab:AddDropdown("Taskbar Align", {"Left","Center","Right"}, "Center", function(v)
    Window:SetTabBarAlignment(v)
    print("[Settings] Taskbar alignment:", v)
    autosaveConfig()
end)

SettingsTab:AddSlider("Taskbar Offset", -200, 200, 0, function(v)
    Window:SetTabBarOffset(v)
    print("[Settings] Taskbar offset:", v)
    autosaveConfig()
end)

SettingsTab:AddSlider("GUI Padding Slider", 0, 40, Window.Padding or 10, function(v)
    Window:SetPadding(v)
    print("[Settings] Padding:", v)
    autosaveConfig()
end)

SettingsTab:AddSlider("GUI Corner Radius", 0, 30, Window.CornerRadius or 18, function(v)
    Window:SetCornerRadius(v)
    print("[Settings] Corner radius:", v)
    autosaveConfig()
end)

SettingsTab:AddSlider("Taskbar Size", 60, 180, (config.DockScale or 1) * 100, function(v)
    local scale = v / 100
    config.DockScale = scale
    Window:SetDockScale(scale)
    print("[Settings] Taskbar size scale:", scale)
    autosaveConfig()
end)

SettingsTab:AddSlider("GUI Width", 300, 900, config.Width, function(v)
    config.Width = v
    Window:SetWidth(v)
    print("[Settings] Width:", v)
    autosaveConfig()
end)

SettingsTab:AddSlider("GUI Height", 220, 700, config.Height, function(v)
    config.Height = v
    Window:SetHeight(v)
    print("[Settings] Height:", v)
    autosaveConfig()
end)

SettingsTab:AddSlider("GUI X Offset", 0, 300, config.AnchorX, function(v)
    config.AnchorX = v
    Window:SetAnchorOffsetX(v)
    print("[Settings] X Offset:", v)
    autosaveConfig()
end)

SettingsTab:AddSlider("GUI Y Offset", -300, 300, config.AnchorY or 0, function(v)
    config.AnchorY = v
    Window:SetAnchorOffsetY(v)
    print("[Settings] Y Offset:", v)
    autosaveConfig()
end)

SettingsTab:AddSlider("Clock Scale", 50, 200, config.ClockScale * 100, function(v)
    local scale = v / 100
    config.ClockScale = scale
    Window:SetClockScale(scale)
    print("[Settings] Clock scale:", scale)
    autosaveConfig()
end)

SettingsTab:AddButton("Destroy UI", function()
    if Window then
        Window:Destroy()
    end
    print("[Settings] UI destroyed")
end)
