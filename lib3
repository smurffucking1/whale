local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

local Library = {}
Library.__index = Library

Library.Themes = {
    Dark = {
        Background  = Color3.fromRGB(20, 20, 25),
        Accent      = Color3.fromRGB(65, 130, 255),
        Accent2     = Color3.fromRGB(60, 60, 80),
        Text        = Color3.fromRGB(240, 240, 255),
        SubText     = Color3.fromRGB(170, 170, 190),
        TabInactive = Color3.fromRGB(35, 35, 45),
        TabActive   = Color3.fromRGB(65, 130, 255),
    },
}

function Library:GetThemes()
    local names = {}
    for name in pairs(self.Themes) do
        table.insert(names, name)
    end
    table.sort(names)
    return names
end

function Library:SetTheme(name)
    if not self.Themes[name] then return end
    self.Theme = self.Themes[name]
    self.Theme.Name = name
    Library.Theme = self.Theme
end

local Window = {}
Window.__index = Window

local Tab = {}
Tab.__index = Tab

local function getOrCreateBlur()
    local blur = Lighting:FindFirstChildOfClass("BlurEffect")
    if not blur then
        blur = Instance.new("BlurEffect")
        blur.Size = 0
        blur.Enabled = false
        blur.Parent = Lighting
    end
    return blur
end

local function applyCornerRadius(uiCorner, window, scale)
    scale = scale or 1
    local r = window.CornerRadius or 10
    uiCorner.CornerRadius = UDim.new(0, math.floor(r * scale))
end

local function getConfigStore()
    getgenv()._tab5_configs = getgenv()._tab5_configs or {}
    return getgenv()._tab5_configs
end

----------------------------------------------------------------------
-- CreateWindow
----------------------------------------------------------------------

function Library:CreateWindow(options)
    options = options or {}

    local selfLib = setmetatable({}, Library)
    selfLib:SetTheme(options.DefaultTheme or "Dark")

    local player = Players.LocalPlayer
    local playerGui = player:WaitForChild("PlayerGui")
    local blur = getOrCreateBlur()

    local mainGui = Instance.new("ScreenGui")
    mainGui.Name = (options.Title or "MyUI") .. "_Main"
    mainGui.IgnoreGuiInset = true
    mainGui.ResetOnSpawn = false
    mainGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    mainGui.DisplayOrder = 9999
    mainGui.Parent = playerGui

    local blocker = Instance.new("TextButton")
    blocker.Name = "InputBlocker"
    blocker.BackgroundTransparency = 1
    blocker.BorderSizePixel = 0
    blocker.Size = UDim2.new(1, 0, 1, 0)
    blocker.Text = ""
    blocker.AutoButtonColor = false
    blocker.Modal = true
    blocker.Parent = mainGui

    local barGui = Instance.new("ScreenGui")
    barGui.Name = (options.Title or "MyUI") .. "_Bar"
    barGui.IgnoreGuiInset = true
    barGui.ResetOnSpawn = false
    barGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    barGui.DisplayOrder = 9999
    barGui.Parent = playerGui

    local thisWindow = setmetatable({
        Library          = selfLib,
        MainGui          = mainGui,
        BarGui           = barGui,
        ClockGui         = nil,
        ClockBar         = nil,
        Root             = nil,
        Container        = nil,
        TabBar           = nil,
        ContentArea      = nil,
        Tabs             = {},
        ActiveTab        = nil,
        Connections      = {},
        DestroyKey       = options.DestroyKey or Enum.KeyCode.RightShift,
        Blur             = blur,
        TabBarAlignment  = "Center",
        TabBarOffset     = 0,
        Padding          = 10,
        CornerRadius     = 18,
        DockScale        = 1,
        AnimateOnOpen    = true,
        Width            = 500,
        Height           = 360,
        AnchorMode       = "Left",
        AnchorOffsetX    = 35,
        AnchorOffsetY    = 0,
        ClockScale       = 1,
        IsOpen           = true,
        HomeContainerPos = nil,
        HomeTabBarPos    = nil,
    }, Window)

    ------------------------------------------------------------------
    -- Clock GUI
    ------------------------------------------------------------------
    local clockGui = Instance.new("ScreenGui")
    clockGui.Name = (options.Title or "MyUI") .. "_Clock"
    clockGui.IgnoreGuiInset = true
    clockGui.ResetOnSpawn = false
    clockGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    clockGui.DisplayOrder = 10000
    clockGui.Parent = playerGui

    local clockBar = Instance.new("Frame")
    clockBar.Name = "ClockBar"
    clockBar.Parent = clockGui
    clockBar.AnchorPoint = Vector2.new(1, 0)
    clockBar.Position = UDim2.new(1, -16, 0, 12)
    clockBar.Size = UDim2.new(0, 90, 0, 26)
    clockBar.BackgroundColor3 = selfLib.Theme.Background
    clockBar.BorderSizePixel = 0

    local clockCorner = Instance.new("UICorner")
    applyCornerRadius(clockCorner, thisWindow, 0.8)
    clockCorner.Parent = clockBar

    local clockLabel = Instance.new("TextLabel")
    clockLabel.Name = "ClockLabel"
    clockLabel.Parent = clockBar
    clockLabel.BackgroundTransparency = 1
    clockLabel.Size = UDim2.new(1, -12, 1, 0)
    clockLabel.Position = UDim2.new(0, 6, 0, 0)
    clockLabel.Font = Enum.Font.Gotham
    clockLabel.TextSize = 14
    clockLabel.TextColor3 = selfLib.Theme.Text
    clockLabel.TextXAlignment = Enum.TextXAlignment.Center
    clockLabel.Text = "00:00"

    thisWindow.ClockGui = clockGui
    thisWindow.ClockBar = clockBar

    local uiScale = Instance.new("UIScale")
    uiScale.Scale = thisWindow.ClockScale
    uiScale.Parent = clockBar

    task.spawn(function()
        while clockGui.Parent do
            local now = os.date("*t")
            clockLabel.Text = string.format("%02d:%02d", now.hour, now.min)
            task.wait(1)
        end
    end)

    ------------------------------------------------------------------
    -- Container + card
    ------------------------------------------------------------------
    local container = Instance.new("Frame")
    container.Name = "MainContainer"
    container.BackgroundTransparency = 1
    container.BorderSizePixel = 0
    container.AnchorPoint = Vector2.new(0, 0.5) -- will be set properly in SetSize
    container.Parent = mainGui
    thisWindow.Container = container

    function thisWindow:SetSize(width, height)
        self.Width  = math.max(300, tonumber(width) or self.Width)
        self.Height = math.max(220, tonumber(height) or self.Height)
        self.AnchorOffsetY = self.AnchorOffsetY or 0

        if self.Container then
            self.Container.Size = UDim2.new(0, self.Width, 0, self.Height)

            if self.AnchorMode == "Left" then
                -- Left side: X from left, Y centered (+ offset)
                self.Container.AnchorPoint = Vector2.new(0, 0.5)
                self.Container.Position    = UDim2.new(
                    0, self.AnchorOffsetX,
                    0.5, self.AnchorOffsetY
                )
            else
                -- Center: full center (+ offset)
                self.Container.AnchorPoint = Vector2.new(0.5, 0.5)
                self.Container.Position    = UDim2.new(
                    0.5, 0,
                    0.5, self.AnchorOffsetY
                )
            end
        end

        self.HomeContainerPos = self.Container.Position
    end

    function thisWindow:SetWidth(w)
        self:SetSize(w, self.Height)
    end

    function thisWindow:SetHeight(h)
        self:SetSize(self.Width, h)
    end

    thisWindow:SetSize(thisWindow.Width, thisWindow.Height)

    local rootFrame = Instance.new("Frame")
    rootFrame.Name = "MainFrame"
    rootFrame.Size = UDim2.new(1, 0, 1, 0)
    rootFrame.BackgroundColor3 = selfLib.Theme.Background
    rootFrame.BorderSizePixel = 0
    rootFrame.Parent = container
    thisWindow.Root = rootFrame

    local corner = Instance.new("UICorner")
    corner.Parent = rootFrame

    local contentArea = Instance.new("Frame")
    contentArea.Name = "Content"
    contentArea.BackgroundColor3 = selfLib.Theme.Background
    contentArea.BorderSizePixel = 0
    contentArea.Size = UDim2.new(1, -24, 1, -24)
    contentArea.Position = UDim2.new(0, 12, 0, 12)
    contentArea.ZIndex = 1
    contentArea.Parent = rootFrame
    thisWindow.ContentArea = contentArea

    local contentCorner = Instance.new("UICorner")
    contentCorner.Parent = contentArea

    ------------------------------------------------------------------
    -- Dock
    ------------------------------------------------------------------
    ------------------------------------------------------------------
    -- Dock
    ------------------------------------------------------------------
    local tabBar = Instance.new("Frame")
    tabBar.Name = "TabBar"
    tabBar.BackgroundColor3 = selfLib.Theme.Background
    tabBar.BorderSizePixel = 0
    tabBar.Size = UDim2.new(0, 420, 0, 56)
    tabBar.AnchorPoint = Vector2.new(0.5, 1)
    tabBar.Position = UDim2.new(0.5, 0, 1, -4)
    tabBar.Parent = barGui

    local tabBarCorner = Instance.new("UICorner")
    tabBarCorner.Parent = tabBar

    -- Holder fills the bar and is centered; icons are centered by UIListLayout
    local tabHolder = Instance.new("Frame")
    tabHolder.Name = "TabHolder"
    tabHolder.BackgroundTransparency = 1
    tabHolder.AnchorPoint = Vector2.new(0.5, 0.5)
    tabHolder.Position = UDim2.new(0.5, 0, 0.5, 0)
    tabHolder.Size = UDim2.new(1, 0, 1, 0)
    tabHolder.Parent = tabBar
    thisWindow.TabBar = tabHolder

    local tabList = Instance.new("UIListLayout")
    tabList.FillDirection = Enum.FillDirection.Horizontal
    tabList.SortOrder = Enum.SortOrder.LayoutOrder
    tabList.Padding = UDim.new(0, 6)
    tabList.HorizontalAlignment = Enum.HorizontalAlignment.Center
    tabList.VerticalAlignment   = Enum.VerticalAlignment.Center
    tabList.Parent = tabHolder

    applyCornerRadius(corner, thisWindow)
    applyCornerRadius(contentCorner, thisWindow)
    applyCornerRadius(tabBarCorner, thisWindow, 1)

    function thisWindow:ApplyPadding()
        local pad = self.Padding
        for _, tabObj in pairs(self.Tabs) do
            local content = tabObj.Content
            if content and content.Parent then
                content.Size = UDim2.new(1, -pad, 1, -pad)
                content.Position = UDim2.new(0, pad / 2, 0, pad / 2)
                local list = content:FindFirstChildOfClass("UIListLayout")
                if list then
                    list.Padding = UDim.new(0, math.max(2, pad / 3))
                end
            end
        end
    end

-- Dock sizing and alignment with fixed edge padding (independent of DockScale)
local function updateTabHolderSize()
    local dockScale = thisWindow.DockScale or 1

    -- Holder must fill the bar and be centered
    tabHolder.AnchorPoint = Vector2.new(0.5, 0.5)
    tabHolder.Position    = UDim2.new(0.5, 0, 0.5, 0)
    tabHolder.Size        = UDim2.new(1, 0, 1, 0)

    -- Collect all app buttons
    local buttons = {}
    for _, child in ipairs(tabHolder:GetChildren()) do
        if child:IsA("TextButton") then
            table.insert(buttons, child)
        end
    end

    -- No buttons yet: small default bar
    local holderAbsX = tabHolder.AbsolutePosition.X
    if #buttons == 0 then
        local defaultWidthPixels  = 120
        local barHeight           = 56 * dockScale
        local barY                = -20

        tabBar.Size = UDim2.new(0, defaultWidthPixels, 0, barHeight)
        tabBar.AnchorPoint = Vector2.new(0.5, 1)
        tabBar.Position    = UDim2.new(0.5, thisWindow.TabBarOffset or 0, 1, barY)

        thisWindow.HomeTabBarPos = tabBar.Position
        return
    end

    -- Force layout before measuring
    tabList:ApplyLayout()

    -- Measure true leftmost/rightmost edges in pixels
    local leftEdgePixels  = math.huge
    local rightEdgePixels = -math.huge

    for _, btn in ipairs(buttons) do
        local btnAbsX = btn.AbsolutePosition.X
        local btnW    = btn.AbsoluteSize.X

        local btnLeft  = btnAbsX - holderAbsX
        local btnRight = btnLeft + btnW

        if btnLeft < leftEdgePixels then
            leftEdgePixels = btnLeft
        end
        if btnRight > rightEdgePixels then
            rightEdgePixels = btnRight
        end
    end

    local appsWidthPixels = math.max(rightEdgePixels - leftEdgePixels, 0)

    -- This is the ONLY place top-level edge padding is defined.
    -- This value is in raw screen pixels and does NOT get scaled.
    local sidePaddingPixels = 12  -- tweak to tighten/loosen ends

    -- Bar width in screen pixels: cluster width + padding on each side
    local barWidthPixels = appsWidthPixels + sidePaddingPixels * 2

    -- Bar height follows DockScale so bar+apps grow together vertically
    local barHeight = 56 * dockScale
    local barY      = -20

    tabBar.Size = UDim2.new(0, barWidthPixels, 0, barHeight)

    -- Align bar horizontally
    local align  = thisWindow.TabBarAlignment
    local offset = thisWindow.TabBarOffset or 0

    if align == "Left" then
        tabBar.AnchorPoint = Vector2.new(0, 1)
        tabBar.Position    = UDim2.new(0, 10 + offset, 1, barY)
    elseif align == "Right" then
        tabBar.AnchorPoint = Vector2.new(1, 1)
        tabBar.Position    = UDim2.new(1, -10 + offset, 1, barY)
    else
        tabBar.AnchorPoint = Vector2.new(0.5, 1)
        tabBar.Position    = UDim2.new(0.5, offset, 1, barY)
    end

    thisWindow.HomeTabBarPos = tabBar.Position
end
    thisWindow.UpdateTabDock = updateTabHolderSize
    tabList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateTabHolderSize)
    updateTabHolderSize()

    thisWindow.HomeContainerPos = thisWindow.Container.Position
    thisWindow.HomeTabBarPos    = tabBar.Position

    ------------------------------------------------------------------
    -- Helpers for icon animation
    ------------------------------------------------------------------
    local function getTabButtons(tabHolder)
        local buttons = {}
        for _, child in ipairs(tabHolder:GetChildren()) do
            if child:IsA("TextButton") then
                table.insert(buttons, child)
            end
        end
        return buttons
    end

    ------------------------------------------------------------------
    -- Animations: card, bar background, then icons
    ------------------------------------------------------------------
local function playOpenAnimation(win)
    win.MainGui.Enabled = true
    win.BarGui.Enabled = true
    if win.ClockGui then win.ClockGui.Enabled = true end

    win.Blur.Enabled = true

    if win.UpdateTabDock then
        win:UpdateTabDock()
    end

    local targetCard = win.HomeContainerPos or win.Container.Position
    local targetBar  = win.HomeTabBarPos or win.TabBar.Position

    if not win.AnimateOnOpen then
        win.Container.Position = targetCard
        win.TabBar.Position    = targetBar
        win.Blur.Size = 18
        return
    end

    win.Blur.Size = 0

    -- Stage 1: card + bar background
    local cardInfo = TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local barInfo  = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    local fromCard = UDim2.new(1.2, 0, targetCard.Y.Scale, targetCard.Y.Offset)
    win.Container.Position = fromCard
    TweenService:Create(win.Container, cardInfo, { Position = targetCard }):Play()

    local fromBar = UDim2.new(targetBar.X.Scale, targetBar.X.Offset, 1, 60)
    win.TabBar.Position = fromBar
    TweenService:Create(win.TabBar, barInfo, { Position = targetBar }):Play()

    TweenService:Create(win.Blur, TweenInfo.new(0.18), { Size = 18 }):Play()

    -- Stage 2: icons slide up onto the bar
    local buttons = getTabButtons(win.TabBar)
    local iconTweenInfo = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    for _, btn in ipairs(buttons) do
        local target = btn.Position
        btn.Position = UDim2.new(target.X.Scale, target.X.Offset, target.Y.Scale + 1, target.Y.Offset)
        TweenService:Create(btn, iconTweenInfo, { Position = target }):Play()
    end

    -- After all tweens should be done, force a final dock layout update
    task.delay(0.25, function()
        if win.UpdateTabDock then
            win:UpdateTabDock()
        end
    end)
end

    local function playCloseAnimation(win)
        if not win.AnimateOnOpen then
            win.MainGui.Enabled = false
            win.BarGui.Enabled = false
            if win.ClockGui then win.ClockGui.Enabled = false end
            win.Blur.Enabled = false
            win.Blur.Size = 0
            return
        end

        local tweenInfo = TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

        -- card to right
        local endPosContainer = UDim2.new(1.2, 0, win.Container.Position.Y.Scale, win.Container.Position.Y.Offset)
        TweenService:Create(win.Container, tweenInfo, { Position = endPosContainer }):Play()

        -- bar background + icons down
        local endPosTab = UDim2.new(win.TabBar.Position.X.Scale, win.TabBar.Position.X.Offset, 1, 60)
        TweenService:Create(win.TabBar, tweenInfo, { Position = endPosTab }):Play()

        local buttons = getTabButtons(win.TabBar)
        for _, btn in ipairs(buttons) do
            local pos = btn.Position
            TweenService:Create(btn, tweenInfo, {
                Position = UDim2.new(pos.X.Scale, pos.X.Offset, 1.5, pos.Y.Offset)
            }):Play()
        end

        TweenService:Create(win.Blur, tweenInfo, { Size = 0 }):Play()

        task.delay(tweenInfo.Time, function()
            win.MainGui.Enabled = false
            win.BarGui.Enabled = false
            if win.ClockGui then win.ClockGui.Enabled = false end
            win.Blur.Enabled = false
            win.Blur.Size = 0
        end)
    end

    ------------------------------------------------------------------
    -- Toggle key with IsOpen flag
    ------------------------------------------------------------------
    thisWindow.IsOpen = true

    table.insert(thisWindow.Connections, UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == thisWindow.DestroyKey then
            if thisWindow.IsOpen then
                thisWindow.IsOpen = false
                playCloseAnimation(thisWindow)
            else
                thisWindow.IsOpen = true
                playOpenAnimation(thisWindow)
            end
        end
    end))

    playOpenAnimation(thisWindow)
    thisWindow.IsOpen = true

    thisWindow.Blur.Enabled = true
    thisWindow.Blur.Size = 18

    return thisWindow
end

----------------------------------------------------------------------
-- Window methods
----------------------------------------------------------------------

function Window:SetToggleKey(keyCode)
    self.DestroyKey = keyCode
end

function Window:SetTabBarAlignment(alignment)
    alignment = alignment or "Center"
    alignment = string.lower(alignment)
    if alignment == "left" then
        self.TabBarAlignment = "Left"
    elseif alignment == "right" then
        self.TabBarAlignment = "Right"
    else
        self.TabBarAlignment = "Center"
    end
    if self.UpdateTabDock then
        self:UpdateTabDock()
    end
end

function Window:SetTabBarOffset(pixels)
    self.TabBarOffset = tonumber(pixels) or 0
    if self.UpdateTabDock then
        self:UpdateTabDock()
    end
end

function Window:SetPadding(pixels)
    self.Padding = math.max(0, tonumber(pixels) or 10)
    if self.UpdateTabDock then
        self:UpdateTabDock()
    end
    if self.ApplyPadding then
        self:ApplyPadding()
    end
end

function Window:SetCornerRadius(pixels)
    self.CornerRadius = math.max(0, tonumber(pixels) or 10)

    if self.Root then
        local mainCorner = self.Root:FindFirstChildOfClass("UICorner")
        if mainCorner then
            applyCornerRadius(mainCorner, self)
        end
    end

    if self.ContentArea then
        local contentCorner = self.ContentArea:FindFirstChildOfClass("UICorner")
        if contentCorner then
            applyCornerRadius(contentCorner, self)
        end
    end

    if self.BarGui then
        local barFrame = self.BarGui:FindFirstChild("TabBar", true)
        if barFrame then
            local barCorner = barFrame:FindFirstChildOfClass("UICorner")
            if barCorner then
                applyCornerRadius(barCorner, self, 1)
            end
        end
    end

    if self.ClockBar then
        local clkCorner = self.ClockBar:FindFirstChildOfClass("UICorner")
        if clkCorner then
            applyCornerRadius(clkCorner, self, 0.8)
        end
    end
end

function Window:SetDockScale(scale)
    self.DockScale = math.clamp(tonumber(scale) or 1, 0.6, 1.8)

    for _, tabObj in pairs(self.Tabs) do
        local btn = tabObj.Button
        if btn then
            local s = self.DockScale
            btn.Size = UDim2.new(0, 40 * s, 0, 40 * s)
            btn.TextSize = 16 * s
        end
    end

    if self.UpdateTabDock then
        self:UpdateTabDock()
    end
end

function Window:SetAnimations(enabled)
    self.AnimateOnOpen = not not enabled
end

function Window:SetAnchorMode(mode)
    mode = string.lower(tostring(mode or "Center"))
    if mode == "left" then
        self.AnchorMode = "Left"
    else
        self.AnchorMode = "Center"
    end
    if self.SetSize then
        self:SetSize(self.Width, self.Height)
    end
end

function Window:SetAnchorOffsetX(offset)
    self.AnchorOffsetX = tonumber(offset) or self.AnchorOffsetX
    if self.SetSize then
        self:SetSize(self.Width, self.Height)
    end
end

function Window:SetAnchorOffsetY(offset)
    self.AnchorOffsetY = tonumber(offset) or self.AnchorOffsetY or 0
    if self.SetSize then
        self:SetSize(self.Width, self.Height)
    end
end

function Window:SetClockScale(scale)
    scale = tonumber(scale) or 1
    scale = math.clamp(scale, 0.5, 2)
    self.ClockScale = scale

    if not self.ClockBar then return end

    local uiScale = self.ClockBar:FindFirstChildOfClass("UIScale")
    if not uiScale then
        uiScale = Instance.new("UIScale")
        uiScale.Parent = self.ClockBar
    end
    uiScale.Scale = scale
end

function Window:SaveConfig(name, data)
    local store = getConfigStore()
    store[name or "default"] = data
end

function Window:LoadConfig(name)
    local store = getConfigStore()
    return store[name or "default"]
end

function Window:Destroy()
    for _, conn in ipairs(self.Connections or {}) do
        if conn.Connected then
            conn:Disconnect()
        end
    end

    if self.MainGui and self.MainGui.Parent then
        self.MainGui:Destroy()
    end
    if self.BarGui and self.BarGui.Parent then
        self.BarGui:Destroy()
    end
    if self.ClockGui and self.ClockGui.Parent then
        self.ClockGui:Destroy()
    end

    if self.Blur then
        self.Blur.Enabled = false
        self.Blur.Size = 0
    end
end

function Window:ShowTab(tab)
    local theme = self.Library.Theme
    if self.ActiveTab == tab then return end
    for _, t in pairs(self.Tabs) do
        t.Content.Visible = false
        t.Button.BackgroundColor3 = theme.TabInactive
        t.Button.TextColor3 = theme.SubText
    end
    tab.Content.Visible = true
    tab.Button.BackgroundColor3 = theme.TabActive
    tab.Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    self.ActiveTab = tab
end

local function getInitials(name)
    name = tostring(name or "")
    if #name == 0 then return "?" end
    return string.upper(string.sub(name, 1, 1))
end

function Window:AddTab(name)
    local theme = self.Library.Theme
    local pad   = self.Padding
    local scale = self.DockScale or 1

    local tabButton = Instance.new("TextButton")
    tabButton.Name   = name .. "_TabButton"
    tabButton.Parent = self.TabBar

    -- Button size
    tabButton.Size = UDim2.new(0, 40 * scale, 0, 40 * scale)

    -- Center with a small negative Y offset so it sits in the visual middle
    tabButton.AnchorPoint = Vector2.new(0.5, 0.5)
    tabButton.Position    = UDim2.new(0.5, 0, 0.5, -4)  -- tweak -4 if needed

    tabButton.BackgroundColor3 = theme.TabInactive
    tabButton.BorderSizePixel  = 0
    tabButton.AutoButtonColor  = true
    tabButton.Font             = Enum.Font.GothamBold
    tabButton.TextSize         = 16 * scale
    tabButton.Text             = getInitials(name)
    tabButton.TextColor3       = theme.Text

    local buttonCorner = Instance.new("UICorner")
    applyCornerRadius(buttonCorner, self, 0.8)
    buttonCorner.Parent = tabButton

    local contentFrame = Instance.new("ScrollingFrame")
    contentFrame.Name = name .. "_Content"
    contentFrame.Parent = self.ContentArea
    contentFrame.Size = UDim2.new(1, -pad, 1, -pad)
    contentFrame.Position = UDim2.new(0, pad / 2, 0, pad / 2)
    contentFrame.BackgroundTransparency = 1
    contentFrame.BorderSizePixel = 0
    contentFrame.ScrollBarThickness = 4
    contentFrame.Visible = false
    contentFrame.ZIndex = 1

    local list = Instance.new("UIListLayout")
    list.FillDirection = Enum.FillDirection.Vertical
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.Padding = UDim.new(0, math.max(2, pad / 3))
    list.Parent = contentFrame

    local tabObj = setmetatable({
        Window  = self,
        Name    = name,
        Button  = tabButton,
        Content = contentFrame,
    }, Tab)

    self.Tabs[name] = tabObj

    local conn = tabButton.MouseButton1Click:Connect(function()
        self:ShowTab(tabObj)
    end)
    table.insert(self.Connections, conn)

    if self.ApplyPadding then
        self:ApplyPadding()
    end

    if not self.ActiveTab then
        self:ShowTab(tabObj)
    end

    if self.UpdateTabDock then
        self:UpdateTabDock()
    end

    return tabObj
end
