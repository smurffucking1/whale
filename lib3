function Tab:AddLabel(text)
    local theme = self.Window.Library.Theme

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = self.Content
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, -10, 0, 24)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = text

    return label
end

function Tab:AddButton(text, callback)
    callback = callback or function() end
    local theme = self.Window.Library.Theme

    local button = Instance.new("TextButton")
    button.Name = "Button"
    button.Parent = self.Content
    button.Size = UDim2.new(1, -10, 0, 28)
    button.BackgroundColor3 = theme.Accent2
    button.BorderSizePixel = 0
    button.AutoButtonColor = true
    button.Font = Enum.Font.Gotham
    button.TextSize = 14
    button.TextColor3 = theme.Text
    button.Text = text

    local corner = Instance.new("UICorner")
    applyCornerRadius(corner, self.Window, 0.8)
    corner.Parent = button

    local conn = button.MouseButton1Click:Connect(function()
        task.spawn(callback)
    end)
    table.insert(self.Window.Connections, conn)

    return button
end

function Tab:AddToggle(text, default, callback)
    callback = callback or function() end
    local theme = self.Window.Library.Theme

    local holder = Instance.new("Frame")
    holder.Name = "Toggle"
    holder.Parent = self.Content
    holder.Size = UDim2.new(1, -10, 0, 28)
    holder.BackgroundTransparency = 1

    local button = Instance.new("TextButton")
    button.Name = "ToggleButton"
    button.Parent = holder
    button.Size = UDim2.new(1, 0, 1, 0)
    button.BackgroundColor3 = theme.Accent2
    button.BorderSizePixel = 0
    button.AutoButtonColor = false
    button.Font = Enum.Font.Gotham
    button.TextSize = 14
    button.TextColor3 = theme.Text
    button.TextXAlignment = Enum.TextXAlignment.Center
    button.Text = text

    local corner = Instance.new("UICorner")
    applyCornerRadius(corner, self.Window, 0.8)
    corner.Parent = button

    local state = default and true or false

    local function update()
        if state then
            button.BackgroundColor3 = theme.Accent
            button.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            button.BackgroundColor3 = theme.Accent2
            button.TextColor3 = theme.Text
        end
    end

    update()
    callback(state)

    local conn = button.MouseButton1Click:Connect(function()
        state = not state
        update()
        task.spawn(callback, state)
    end)
    table.insert(self.Window.Connections, conn)

    return {
        Set = function(_, v)
            state = v and true or false
            update()
            callback(state)
        end,
        Get = function()
            return state
        end,
    }
end

function Tab:AddSlider(text, min, max, default, callback)
    callback = callback or function() end
    min = min or 0
    max = max or 100
    default = default or min

    local theme = self.Window.Library.Theme

    local holder = Instance.new("Frame")
    holder.Name = "Slider"
    holder.Parent = self.Content
    holder.Size = UDim2.new(1, -10, 0, 40)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = holder
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 0, 0, 0)
    label.Size = UDim2.new(1, -60, 0.5, 0)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = string.format("%s: %d", text, default)

    local valueBox = Instance.new("TextBox")
    valueBox.Name = "ValueBox"
    valueBox.Parent = holder
    valueBox.Size = UDim2.new(0, 50, 0, 20)
    valueBox.Position = UDim2.new(1, -52, 0, 2)
    valueBox.BackgroundColor3 = theme.Accent2
    valueBox.BorderSizePixel = 0
    valueBox.Font = Enum.Font.Gotham
    valueBox.TextSize = 14
    valueBox.TextColor3 = theme.Text
    valueBox.Text = tostring(default)
    valueBox.ClearTextOnFocus = false

    local vbCorner = Instance.new("UICorner")
    applyCornerRadius(vbCorner, self.Window, 0.6)
    vbCorner.Parent = valueBox

    local bar = Instance.new("Frame")
    bar.Name = "Bar"
    bar.Parent = holder
    bar.BackgroundColor3 = theme.Accent2
    bar.BorderSizePixel = 0
    bar.Position = UDim2.new(0, 0, 0.6, 0)
    bar.Size = UDim2.new(1, 0, 0, 6)

    local barCorner = Instance.new("UICorner")
    applyCornerRadius(barCorner, self.Window, 0.3)
    barCorner.Parent = bar

    local fill = Instance.new("Frame")
    fill.Name = "Fill"
    fill.Parent = bar
    fill.BackgroundColor3 = theme.Accent
    fill.BorderSizePixel = 0
    fill.Size = UDim2.new(0, 0, 1, 0)

    local fillCorner = Instance.new("UICorner")
    applyCornerRadius(fillCorner, self.Window, 0.3)
    fillCorner.Parent = fill

    local knob = Instance.new("Frame")
    knob.Name = "Knob"
    knob.Parent = bar
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.Size = UDim2.new(0, 10, 0, 14)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(0, 0, 0.5, 0)

    local knobCorner = Instance.new("UICorner")
    applyCornerRadius(knobCorner, self.Window, 1)
    knobCorner.Parent = knob

    local dragging = false
    local currentValue = default

    local function applyValue(v)
        v = math.clamp(v, min, max)
        local a = (v - min) / (max - min)
        currentValue = v
        fill.Size = UDim2.new(a, 0, 1, 0)
        knob.Position = UDim2.new(a, 0, 0.5, 0)
        label.Text = string.format("%s: %d", text, v)
        valueBox.Text = tostring(v)
        callback(v)
    end

    local function setFromX(x)
        local absPos = bar.AbsolutePosition.X
        local absSize = bar.AbsoluteSize.X
        local alpha = math.clamp((x - absPos) / absSize, 0, 1)
        local value = math.floor(min + (max - min) * alpha + 0.5)
        applyValue(value)
    end

    local uis = UserInputService

    local c1 = bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            setFromX(input.Position.X)
        end
    end)
    table.insert(self.Window.Connections, c1)

    local c2 = bar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    table.insert(self.Window.Connections, c2)

    local c3 = uis.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            setFromX(input.Position.X)
        end
    end)
    table.insert(self.Window.Connections, c3)

    valueBox.FocusLost:Connect(function(enterPressed)
        if not enterPressed then return end
        local num = tonumber(valueBox.Text)
        if not num then
            valueBox.Text = tostring(currentValue)
            return
        end
        applyValue(num)
    end)

    applyValue(default)

    return {
        Set = function(_, v) applyValue(v) end,
        Get = function() return currentValue end,
    }
end

function Tab:AddKeybind(text, initialKey, callback)
    callback = callback or function() end

    local theme = self.Window.Library.Theme

    local holder = Instance.new("Frame")
    holder.Name = "Keybind"
    holder.Parent = self.Content
    holder.Size = UDim2.new(1, -10, 0, 28)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = holder
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 0, 0, 0)
    label.Size = UDim2.new(1, -80, 1, 0)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = text

    local button = Instance.new("TextButton")
    button.Name = "KeyButton"
    button.Parent = holder
    button.Size = UDim2.new(0, 60, 0, 24)
    button.Position = UDim2.new(1, -62, 0.5, -12)
    button.BackgroundColor3 = theme.Accent2
    button.BorderSizePixel = 0
    button.Font = Enum.Font.Gotham
    button.TextSize = 12
    button.TextColor3 = theme.Text

    local corner = Instance.new("UICorner")
    applyCornerRadius(corner, self.Window, 0.6)
    corner.Parent = button

    local currentKey = initialKey
    if typeof(currentKey) ~= "EnumItem" or currentKey.EnumType ~= Enum.KeyCode then
        currentKey = Enum.KeyCode.RightShift
    end
    button.Text = currentKey.Name

    local listening = false

    local function setKey(keyCode)
        if typeof(keyCode) ~= "EnumItem" or keyCode.EnumType ~= Enum.KeyCode then
            return
        end
        currentKey = keyCode
        button.Text = currentKey.Name
        callback(currentKey)
    end

    local c = button.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true
        button.Text = "..."
        local conn
        conn = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.KeyCode ~= Enum.KeyCode.Unknown then
                setKey(input.KeyCode)
                listening = false
                if conn and conn.Connected then
                    conn:Disconnect()
                end
            end
        end)
    end)
    table.insert(self.Window.Connections, c)

    return {
        Get = function() return currentKey end,
        Set = function(_, keyCode) setKey(keyCode) end,
    }
end

function Tab:AddTextBox(labelText, placeholder, defaultText, onSubmit)
    onSubmit = onSubmit or function() end

    local theme = self.Window.Library.Theme

    local holder = Instance.new("Frame")
    holder.Name = "TextBox"
    holder.Parent = self.Content
    holder.Size = UDim2.new(1, -10, 0, 28)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = holder
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 0, 0, 0)
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = labelText

    local box = Instance.new("TextBox")
    box.Name = "Input"
    box.Parent = holder
    box.Size = UDim2.new(0.5, -4, 1, 0)
    box.Position = UDim2.new(0.5, 4, 0, 0)
    box.BackgroundColor3 = theme.Accent2
    box.BorderSizePixel = 0
    box.Font = Enum.Font.Gotham
    box.TextSize = 14
    box.TextColor3 = theme.Text
    box.PlaceholderText = placeholder or ""
    box.Text = defaultText or ""

    local corner = Instance.new("UICorner")
    applyCornerRadius(corner, self.Window, 0.8)
    corner.Parent = box

    box.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            onSubmit(box.Text)
        end
    end)

    return box
end

function Tab:AddDropdown(text, items, default, callback)
    callback = callback or function() end
    items = items or {}

    local theme = self.Window.Library.Theme

    local holder = Instance.new("Frame")
    holder.Name = "Dropdown"
    holder.Parent = self.Content
    holder.Size = UDim2.new(1, -10, 0, 32)
    holder.BackgroundTransparency = 1

    local header = Instance.new("Frame")
    header.Name = "Header"
    header.Parent = holder
    header.BackgroundTransparency = 1
    header.Size = UDim2.new(1, 0, 0, 32)

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = header
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = text

    local button = Instance.new("TextButton")
    button.Name = "MainButton"
    button.Parent = header
    button.Size = UDim2.new(0.5, -4, 1, 0)
    button.Position = UDim2.new(0.5, 4, 0, 0)
    button.BackgroundColor3 = theme.Accent2
    button.BorderSizePixel = 0
    button.Font = Enum.Font.Gotham
    button.TextSize = 14
    button.TextColor3 = theme.Text
    button.TextXAlignment = Enum.TextXAlignment.Left
    button.Text = tostring(default or "Select")

    local btnCorner = Instance.new("UICorner")
    applyCornerRadius(btnCorner, self.Window, 0.8)
    btnCorner.Parent = button

    local menu = Instance.new("Frame")
    menu.Name = "Menu"
    menu.Parent = holder
    menu.BackgroundColor3 = theme.Background
    menu.BorderSizePixel = 0
    menu.Position = UDim2.new(0.5, 4, 0, 34)
    menu.Size = UDim2.new(0.5, -4, 0, 0)
    menu.Visible = false
    menu.ClipsDescendants = true
    menu.ZIndex = 50

    local menuCorner = Instance.new("UICorner")
    applyCornerRadius(menuCorner, self.Window, 0.8)
    menuCorner.Parent = menu

    local list = Instance.new("UIListLayout")
    list.FillDirection = Enum.FillDirection.Vertical
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.Padding = UDim.new(0, 2)
    list.Parent = menu

    local opened = false
    local currentValue = default
    local baseHeight = 32
    local searchBox

    local function updateHolderHeight()
        if opened then
            holder.Size = UDim2.new(1, -10, 0, baseHeight + menu.Size.Y.Offset + 4)
        else
            holder.Size = UDim2.new(1, -10, 0, baseHeight)
        end
    end

    local function rebuildMenu(filterText)
        filterText = filterText or ""
        filterText = string.lower(filterText)

        for _, child in ipairs(menu:GetChildren()) do
            if child:IsA("TextButton") or child:IsA("TextBox") then
                child:Destroy()
            end
        end

        searchBox = Instance.new("TextBox")
        searchBox.Name = "Search"
        searchBox.Parent = menu
        searchBox.BackgroundColor3 = theme.Accent2
        searchBox.BorderSizePixel = 0
        searchBox.Size = UDim2.new(1, -4, 0, 24)
        searchBox.Position = UDim2.new(0, 2, 0, 2)
        searchBox.Font = Enum.Font.Gotham
        searchBox.TextSize = 14
        searchBox.TextColor3 = theme.Text
        searchBox.PlaceholderText = "Search..."
        searchBox.Text = filterText or ""
        searchBox.ZIndex = 51

        local searchCorner = Instance.new("UICorner")
        applyCornerRadius(searchCorner, self.Window, 0.6)
        searchCorner.Parent = searchBox

        local visibleCount = 0

        local function addOption(v)
            local opt = Instance.new("TextButton")
            opt.Name = "Option"
            opt.Parent = menu
            opt.BackgroundColor3 = theme.Accent2
            opt.BorderSizePixel = 0
            opt.Size = UDim2.new(1, -4, 0, 24)
            opt.Font = Enum.Font.Gotham
            opt.TextSize = 14
            opt.TextColor3 = theme.Text
            opt.TextXAlignment = Enum.TextXAlignment.Left
            opt.Text = tostring(v)
            opt.ZIndex = 51

            local c = Instance.new("UICorner")
            applyCornerRadius(c, self.Window, 0.6)
            c.Parent = opt

            visibleCount += 1

            local conn = opt.MouseButton1Click:Connect(function()
                currentValue = v
                button.Text = tostring(v)
                callback(v)
                opened = false
                menu.Visible = false
                updateHolderHeight()
            end)
            table.insert(self.Window.Connections, conn)
        end

        for _, v in ipairs(items) do
            local s = tostring(v)
            if filterText == "" or string.find(string.lower(s), filterText, 1, true) then
                addOption(v)
            end
        end

        local h = 24 + 4 + visibleCount * 26 + 4
        menu.Size = UDim2.new(menu.Size.X.Scale, menu.Size.X.Offset, 0, h)
        updateHolderHeight()

        searchBox:GetPropertyChangedSignal("Text"):Connect(function()
            rebuildMenu(searchBox.Text)
        end)
    end

    rebuildMenu("")

    local conn = button.MouseButton1Click:Connect(function()
        opened = not opened
        if opened then
            rebuildMenu(searchBox and searchBox.Text or "")
        end
        menu.Visible = opened
        updateHolderHeight()
    end)
    table.insert(self.Window.Connections, conn)

    if default ~= nil then
        currentValue = default
        button.Text = tostring(default)
        callback(default)
    end

    local api = {}

    function api:Set(value)
        currentValue = value
        button.Text = tostring(value)
        callback(value)
    end

    function api:Get()
        return currentValue
    end

    function api:SetItems(newItems)
        items = newItems or {}
        if opened then
            rebuildMenu(searchBox and searchBox.Text or "")
        end
    end

    return api
end

return Library
