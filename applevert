    valuePicker.AnchorPoint = Vector2.new(0.5,0.5)
    valuePicker.Position = UDim2.new(0.5,0,0,0)
    valuePicker.BackgroundColor3 = Color3.new(1,1,1)
    valuePicker.BorderSizePixel = 0
    valuePicker.Parent = valueBar
    local vpC = Instance.new("UICorner", valuePicker); vpC.CornerRadius = UDim.new(0,2)

    local preview = Instance.new("Frame")
    preview.Size = UDim2.new(0,40,0,40)
    preview.Position = UDim2.new(0,210,0,40)
    preview.BackgroundColor3 = startColor
    preview.BorderSizePixel = 0
    preview.Parent = box
    local prC = Instance.new("UICorner", preview); prC.CornerRadius = UDim.new(0,6)

    local okBtn = Instance.new("TextButton")
    okBtn.Size = UDim2.new(0.5,-8,0,28)
    okBtn.Position = UDim2.new(0,6,1,-34)
    okBtn.BackgroundColor3 = Color3.fromRGB(60,60,80)
    okBtn.BorderSizePixel = 0
    okBtn.Font = Enum.Font.GothamBold
    okBtn.TextSize = 14
    okBtn.TextColor3 = Color3.fromRGB(230,230,240)
    okBtn.Text = "OK"
    okBtn.Parent = box
    local okC = Instance.new("UICorner", okBtn); okC.CornerRadius = UDim.new(0,4)

    local cancelBtn = Instance.new("TextButton")
    cancelBtn.Size = UDim2.new(0.5,-8,0,28)
    cancelBtn.Position = UDim2.new(0.5,2,1,-34)
    cancelBtn.BackgroundColor3 = Color3.fromRGB(50,50,60)
    cancelBtn.BorderSizePixel = 0
    cancelBtn.Font = Enum.Font.Gotham
    cancelBtn.TextSize = 14
    cancelBtn.TextColor3 = Color3.fromRGB(230,230,240)
    cancelBtn.Text = "Cancel"
    cancelBtn.Parent = box
    local caC = Instance.new("UICorner", cancelBtn); caC.CornerRadius = UDim.new(0,4)

    local h,s,v = startColor:ToHSV()

    local function updatePreview()
        preview.BackgroundColor3 = Color3.fromHSV(h,s,v)
    end
    updatePreview()

    local draggingWheel, draggingValue = false,false

    local function updateFromWheel(pos)
        local center = wheel.AbsolutePosition + wheel.AbsoluteSize/2
        local rel = Vector2.new(pos.X-center.X,pos.Y-center.Y)
        local radius = wheel.AbsoluteSize.X/2
        local dist = math.min(rel.Magnitude,radius)
        local angle = math.atan2(rel.Y, rel.X)
        h = (angle/(2*math.pi)) % 1
        s = dist / radius

        local px = radius + math.cos(angle)*dist
        local py = radius + math.sin(angle)*dist
        wheelPicker.Position = UDim2.new(0,px,0,py)

        updatePreview()
    end

    local function updateFromValue(y)
        local bp = valueBar.AbsolutePosition
        local bs = valueBar.AbsoluteSize
        local clamped = math.clamp(y, bp.Y, bp.Y+bs.Y)
        local alpha = (clamped - bp.Y)/bs.Y
        v = 1-alpha
        valuePicker.Position = UDim2.new(0.5,0,1-alpha,0)
        updatePreview()
    end

    wheel.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingWheel = true
            updateFromWheel(UIS:GetMouseLocation())
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    draggingWheel = false
                end
            end)
        end
    end)

    valueBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingValue = true
            updateFromValue(UIS:GetMouseLocation().Y)
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    draggingValue = false
                end
            end)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if draggingWheel then
            updateFromWheel(UIS:GetMouseLocation())
        elseif draggingValue then
            updateFromValue(UIS:GetMouseLocation().Y)
        end
    end)

    okBtn.MouseButton1Click:Connect(function()
        if callback then callback(preview.BackgroundColor3) end
        pickerGui:Destroy()
    end)

    cancelBtn.MouseButton1Click:Connect(function()
        pickerGui:Destroy()
    end)
end

--============= WINDOW CREATION =============

local function clampNum(v, mn, mx)
    return (v < mn and mn) or (v > mx and mx) or v
end

function UILib:CreateWindow(id)
    id = id or ("Window_"..tostring(#self.Windows+1))

    local CurrentThemeName = "Default"
    local CurrentTheme = Themes[CurrentThemeName]

    local existing = CoreGui:FindFirstChild("AppleUILib_"..id)
    if existing then existing:Destroy() end

    local gui = Instance.new("ScreenGui")
    gui.Name = "AppleUILib_"..id
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = CoreGui

    local frame = Instance.new("Frame")
    frame.Name = "Window"
    frame.AnchorPoint = Vector2.new(0,0)
    frame.Size = UDim2.new(0,480,0,340)
    frame.Position = UDim2.new(0.5,-240,0.5,-170)
    frame.BackgroundColor3 = CurrentTheme.WindowColor
    frame.BorderSizePixel = 0
    frame.Active = true
    frame.Parent = gui
    local fC = Instance.new("UICorner", frame); fC.CornerRadius = UDim.new(0,12)

    local topStrip = Instance.new("Frame")
    topStrip.BackgroundColor3 = CurrentTheme.StripColor
    topStrip.BorderSizePixel = 0
    topStrip.Size = UDim2.new(1,-16,0,20)
    topStrip.Position = UDim2.new(0,8,0,4)
    topStrip.Parent = frame
    local tsC = Instance.new("UICorner", topStrip); tsC.CornerRadius = UDim.new(1,0)

    local function makeDot(color, x)
        local b = Instance.new("TextButton")
        b.BackgroundColor3 = color
        b.BorderSizePixel = 0
        b.Size = UDim2.new(0,14,0,14)
        b.Position = UDim2.new(0,x,0,3)
        b.Text = ""
        b.AutoButtonColor = false
        b.Parent = topStrip
        local c = Instance.new("UICorner", b); c.CornerRadius = UDim.new(1,0)
        return b
    end

    local closeBtn      = makeDot(CurrentTheme.DotColorRed,6)
    local minimizeBtn   = makeDot(CurrentTheme.DotColorYellow,24)
    local fullscreenBtn = makeDot(CurrentTheme.DotColorGreen,42)

    local content = Instance.new("Frame")
    content.Name = "Content"
    content.BackgroundTransparency = 1
    content.Size = UDim2.new(1,-24,1,-40)
    content.Position = UDim2.new(0,12,0,32)
    content.Parent = frame

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0,6)
    layout.Parent = content

    local function newRow(h)
        local r = Instance.new("Frame")
        r.Size = UDim2.new(1,0,0,h or 28)
        r.BackgroundTransparency = 1
        r.Parent = content
        return r
    end

    -- Drag
    local dragging = false
    local dragStart, startPos
    local function pointIn(inst,pos)
        local p = inst.AbsolutePosition
        local s = inst.AbsoluteSize
        return pos.X>=p.X and pos.X<=p.X+s.X and pos.Y>=p.Y and pos.Y<=p.Y+s.Y
    end

    topStrip.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mp = UIS:GetMouseLocation()
            if pointIn(closeBtn,mp) or pointIn(minimizeBtn,mp) or pointIn(fullscreenBtn,mp) then
                return
            end
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale,startPos.X.Offset+delta.X,startPos.Y.Scale,startPos.Y.Offset+delta.Y)
        end
    end)

    -- Resize pad
    local resizePad = Instance.new("Frame")
    resizePad.AnchorPoint = Vector2.new(1,1)
    resizePad.Size = UDim2.new(0,22,0,22)
    resizePad.Position = UDim2.new(1,-6,1,-6)
    resizePad.BackgroundColor3 = Color3.fromRGB(60,60,72)
    resizePad.BorderSizePixel = 0
    resizePad.Parent = frame
    local rpC = Instance.new("UICorner", resizePad); rpC.CornerRadius = UDim.new(1,0)
    for i=0,2 do
        local d = Instance.new("Frame")
        d.Size = UDim2.new(0,3,0,3)
        d.Position = UDim2.new(1,-6-i*4,1,-6)
        d.AnchorPoint = Vector2.new(1,1)
        d.BackgroundColor3 = Color3.fromRGB(200,200,210)
        d.BorderSizePixel = 0
        d.Parent = resizePad
    end

    local resizing, resizeStart, startSize = false,nil,nil
    resizePad.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = true
            resizeStart = UIS:GetMouseLocation()
            startSize = frame.Size
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    resizing = false
                end
            end)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if resizing then
            local mp = UIS:GetMouseLocation()
            local delta = mp - resizeStart
            local newW = clampNum(startSize.X.Offset + delta.X, 260, 900)
            local newH = clampNum(startSize.Y.Offset + delta.Y, 220, 700)
            frame.Size = UDim2.new(0,newW,0,newH)
        end
    end)

    -- Close/minimize/fullscreen
    closeBtn.MouseButton1Click:Connect(function() gui:Destroy() end)
    minimizeBtn.MouseButton1Click:Connect(function() frame.Visible=false end)

    local savedSize, savedPos, fullscreen = frame.Size, frame.Position, false
    fullscreenBtn.MouseButton1Click:Connect(function()
        if not fullscreen then
            savedSize, savedPos = frame.Size, frame.Position
            frame.Size = UDim2.new(0,800,0,520)
            frame.Position = UDim2.new(0.5,-400,0.5,-260)
            fullscreen = true
        else
            frame.Size, frame.Position = savedSize, savedPos
            fullscreen = false
        end
    end)

    UIS.InputBegan:Connect(function(input,gp)
        if gp then return end
        if input.KeyCode == Enum.KeyCode.RightControl then
            frame.Visible = not frame.Visible
        end
    end)

    --==== WINDOW API ==== 

    local Window = {}
    Window.Frame = frame
    Window.Content = content
    Window.Id = id

