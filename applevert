    -- NEW: AddTabs
    function Window:AddTabs(tabNames, defaultIndex)
        tabNames = tabNames or {"Tab 1"}
        defaultIndex = defaultIndex or 1

        local tabRow = newRow(28)
        
        local tabBar = Instance.new("Frame")
        tabBar.Size = UDim2.new(1,-4,0,28)
        tabBar.Position = UDim2.new(0,0,0,0)
        tabBar.BackgroundTransparency = 1
        tabBar.Parent = tabRow

        local tabLayout = Instance.new("UIListLayout")
        tabLayout.FillDirection = Enum.FillDirection.Horizontal
        tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
        tabLayout.Padding = UDim.new(0,4)
        tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
        tabLayout.Parent = tabBar

        local tabContentArea = Instance.new("Frame")
        tabContentArea.Size = UDim2.new(1,-4,1,-32)
        tabContentArea.Position = UDim2.new(0,0,0,32)
        tabContentArea.BackgroundTransparency = 1
        tabContentArea.Parent = tabRow

        local contentLayout = Instance.new("UIListLayout")
        contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
        contentLayout.Padding = UDim.new(0,6)
        contentLayout.Parent = tabContentArea

        local tabs = {}
        local currentTab = nil

        local function createTab(name, idx)
            local tabBtn = Instance.new("TextButton")
            tabBtn.Size = UDim2.new(0,0,1,0)
            tabBtn.BackgroundColor3 = Color3.fromRGB(40,40,50)
            tabBtn.BorderSizePixel = 0
            tabBtn.Font = Enum.Font.Gotham
            tabBtn.TextSize = 13
            tabBtn.TextColor3 = Color3.fromRGB(230,230,240)
            tabBtn.Text = name
            tabBtn.Parent = tabBar
            
            -- Make buttons expand to fit text
            tabBtn cluttered = false
            tabBtn:GetPropertyChangedSignal("Text"):Connect(function()
                tabBtn.Size = UDim2.new(0,tabBtn.TextBounds.X + 16,1,0)
            end)
            tabBtn.Text = name -- trigger size update

            local tabPage = Instance.new("Frame")
            tabPage.Size = UDim2.new(1,0,1,0)
            tabPage.BackgroundTransparency = 1
            tabPage.Visible = false
            tabPage.Parent = tabContentArea

            local tabPageLayout = Instance.new("UIListLayout")
            tabPageLayout.SortOrder = Enum.SortOrder.LayoutOrder
            tabPageLayout.Padding = UDim.new(0,6)
            tabPageLayout.Parent = tabPage

            tabs[idx] = {
                Button = tabBtn,
                Page = tabPage,
                Name = name,
                Elements = {},
            }

            tabBtn.MouseButton1Click:Connect(function()
                if currentTab then
                    currentTab.Page.Visible = false
                end
                tabs[idx].Page.Visible = true
                currentTab = tabs[idx]
                
                -- Update button styles
                for i,tab in ipairs(tabs) do
                    if i == idx then
                        tab.Button.BackgroundColor3 = CurrentTheme.DotColorGreen
                        tab.Button.Font = Enum.Font.GothamBold
                    else
                        tab.Button.BackgroundColor3 = Color3.fromRGB(40,40,50)
                        tab.Button.Font = Enum.Font.Gotham
                    end
                end
            end)

            return {
                AddDropdown = function(labelText, options, defaultIndex, callback)
                    local elem = tabs[idx].Page:AddDropdown(labelText, options, defaultIndex, callback)
                    tabs[idx].Elements[#tabs[idx].Elements+1] = elem
                    return elem
                end,
                AddColorPicker = function(labelText, startColor, callback)
                    local elem = tabs[idx].Page:AddColorPicker(labelText, startColor, callback)
                    tabs[idx].Elements[#tabs[idx].Elements+1] = elem
                    return elem
                end,
                AddSlider = function(labelText, minVal, maxVal, defaultVal, step, callback)
                    local elem = tabs[idx].Page:AddSlider(labelText, minVal, maxVal, defaultVal, step, callback)
                    tabs[idx].Elements[#tabs[idx].Elements+1] = elem
                    return elem
                end,
                AddTextBox = function(labelText, placeholder, callback)
                    local elem = tabs[idx].Page:AddTextBox(labelText, placeholder, callback)
                    tabs[idx].Elements[#tabs[idx].Elements+1] = elem
                    return elem
                end,
                AddButton = function(buttonText, callback)
                    local elem = tabs[idx].Page:AddButton(buttonText, callback)
                    tabs[idx].Elements[#tabs[idx].Elements+1] = elem
                    return elem
                end,
                AddLabel = function(text)
                    local lbl = Instance.new("TextLabel")
                    lbl.Size = UDim2.new(1,-4,0,20)
                    lbl.BackgroundTransparency = 1
                    lbl.Font = Enum.Font.Gotham
                    lbl.TextSize = 14
                    lbl.TextColor3 = Color3.fromRGB(230,230,240)
                    lbl.TextXAlignment = Enum.TextXAlignment.Left
                    lbl.Text = text or ""
                    lbl.Parent = tabs[idx].Page
                    tabs[idx].Elements[#tabs[idx].Elements+1] = lbl
                    return lbl
                end,
            }
        end

        for i,name in ipairs(tabNames) do
            createTab(name, i)
        end

        -- Activate default tab
        if tabs[defaultIndex] then
            tabs[defaultIndex].Page.Visible = true
            currentTab = tabs[defaultIndex]
            tabs[defaultIndex].Button.BackgroundColor3 = CurrentTheme.DotColorGreen
            tabs[defaultIndex].Button.Font = Enum.Font.GothamBold
        end

        return {
            Select = function(idx)
                if tabs[idx] then
                    tabs[idx].Button.MouseButton1Click:Fire()
                end
            end,
            GetSelected = function() return currentTab end,
            GetTab = function(idx) return tabs[idx] end,
        }
    end

    -- AddDropdown monkey-patch for tabs (to work inside tab pages)
    local originalAddRow = newRow
    function Window:AddDropdown(labelText, options, defaultIndex, callback)
        return self:AddDropdown(labelText, options, defaultIndex, callback)
    end

    -- Built-in theme controls for this window
    do
        local ddTheme = Window:AddDropdown("Theme", (function()
            local keys = {}
            for name,_ in pairs(Themes) do table.insert(keys,name) end
            table.sort(keys)
            return keys
        end)(), 1, function(name)
            local t = Themes[name]
            if not t then return end
            CurrentThemeName = name
            CurrentTheme = t
            frame.BackgroundColor3 = t.WindowColor
            topStrip.BackgroundColor3 = t.StripColor
            closeBtn.BackgroundColor3 = t.DotColorRed
            minimizeBtn.BackgroundColor3 = t.DotColorYellow
            fullscreenBtn.BackgroundColor3 = t.DotColorGreen
        end)

        local saveRow = newRow(28)
        local sl = Instance.new("TextLabel")
        sl.BackgroundTransparency = 1
        sl.Size = UDim2.new(0.35,-4,1,0)
        sl.Position = UDim2.new(0,0,0,0)
        sl.Font = Enum.Font.Gotham
        sl.TextSize = 14
        sl.TextColor3 = Color3.fromRGB(230,230,240)
        sl.TextXAlignment = Enum.TextXAlignment.Left
        sl.Text = "Save theme as"
        sl.Parent = saveRow

        local nameBox = Instance.new("TextBox")
        nameBox.AnchorPoint = Vector2.new(1,0)
        nameBox.Position = UDim2.new(1,-70,0,0)
        nameBox.Size = UDim2.new(0.35,0,1,0)
        nameBox.BackgroundColor3 = Color3.fromRGB(40,40,50)
        nameBox.BorderSizePixel = 0
        nameBox.Font = Enum.Font.Gotham
        nameBox.TextSize = 14
        nameBox.TextColor3 = Color3.fromRGB(240,240,250)
        nameBox.ClearTextOnFocus = false
        nameBox.TextXAlignment = Enum.TextXAlignment.Left
        nameBox.Text = "MyTheme"
        nameBox.Parent = saveRow
        local nbC = Instance.new("UICorner", nameBox); nbC.CornerRadius = UDim.new(0,4)

        local saveBtn = Instance.new("TextButton")
        saveBtn.AnchorPoint = Vector2.new(1,0)
        saveBtn.Position = UDim2.new(1,0,0,0)
        saveBtn.Size = UDim2.new(0,70,1,0)
        saveBtn.BackgroundColor3 = Color3.fromRGB(60,60,80)
        saveBtn.BorderSizePixel = 0
        saveBtn.Font = Enum.Font.GothamBold
        saveBtn.TextSize = 14
        saveBtn.TextColor3 = Color3.fromRGB(230,230,240)
        saveBtn.Text = "Save"
        saveBtn.Parent = saveRow
        local sbC = Instance.new("UICorner", saveBtn); sbC.CornerRadius = UDim.new(0,4)

        saveBtn.MouseButton1Click:Connect(function()
            local name = nameBox.Text:gsub("^%s+",""):gsub("%s+$","")
            if name == "" then return end
            Themes[name] = {
                WindowColor = frame.BackgroundColor3,
                StripColor  = topStrip.BackgroundColor3,
                DotColorRed = closeBtn.BackgroundColor3,
                DotColorYellow = minimizeBtn.BackgroundColor3,
                DotColorGreen  = fullscreenBtn.BackgroundColor3,
            }
            saveThemes()
            -- refresh dropdown options
            local keys = {}
            for n,_ in pairs(Themes) do table.insert(keys,n) end
            table.sort(keys)
            ddTheme.Rebuild()
        end)
    end

    self.Windows[id] = Window
    return Window
end

