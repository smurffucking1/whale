local HttpService = game:GetService("HttpService")

local UILib = {}
UILib.__index = UILib
UILib.Windows = {}

--============= FS + THEMES =============

local ROOT_FOLDER = "APPLE_REC"
local THEMES_FILE = ROOT_FOLDER .. "/themes.json"

local function fsSupported()
    return isfolder and makefolder and isfile and readfile and writefile
end

local Themes = {
    Default = {
        WindowColor = Color3.fromRGB(25, 25, 32),
        StripColor  = Color3.fromRGB(40, 40, 50),
        DotColorRed = Color3.fromRGB(255, 95, 86),
        DotColorYellow = Color3.fromRGB(255, 189, 46),
        DotColorGreen = Color3.fromRGB(39, 201, 63),
    }
}

local function loadThemes()
    if not fsSupported() then return end
    if not isfolder(ROOT_FOLDER) then makefolder(ROOT_FOLDER) end
    if not isfile(THEMES_FILE) then return end

    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(THEMES_FILE))
    end)
    if ok and type(decoded) == "table" then
        for name, t in pairs(decoded) do
            if type(t) == "table" and t.WindowColor and t.StripColor then
                Themes[name] = {
                    WindowColor = Color3.new(t.WindowColor.R,t.WindowColor.G,t.WindowColor.B),
                    StripColor  = Color3.new(t.StripColor.R, t.StripColor.G, t.StripColor.B),
                    DotColorRed = Color3.new(t.DotColorRed.R,t.DotColorRed.G,t.DotColorRed.B),
                    DotColorYellow = Color3.new(t.DotColorYellow.R,t.DotColorYellow.G,t.DotColorYellow.B),
                    DotColorGreen  = Color3.new(t.DotColorGreen.R, t.DotColorGreen.G, t.DotColorGreen.B),
                }
            end
        end
    end
end

local function saveThemes()
    if not fsSupported() then return end
    if not isfolder(ROOT_FOLDER) then makefolder(ROOT_FOLDER) end

    local serial = {}
    for name,t in pairs(Themes) do
        serial[name] = {
            WindowColor = {R=t.WindowColor.R,G=t.WindowColor.G,B=t.WindowColor.B},
            StripColor  = {R=t.StripColor.R, G=t.StripColor.G, B=t.StripColor.B},
            DotColorRed = {R=t.DotColorRed.R,G=t.DotColorRed.G,B=t.DotColorRed.B},
            DotColorYellow = {R=t.DotColorYellow.R,G=t.DotColorYellow.G,B=t.DotColorYellow.B},
            DotColorGreen  = {R=t.DotColorGreen.R, G=t.DotColorGreen.G, B=t.DotColorGreen.B},
        }
    end

    local ok, encoded = pcall(function()
        return HttpService:JSONEncode(serial)
    end)
    if ok then
        writefile(THEMES_FILE, encoded)
    end
end

loadThemes()

