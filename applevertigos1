        local function selectTab(index)
            if not tabs[index] then return end
            currentTabIndex = index
            refreshTabButtons()
            for i, t in ipairs(tabs) do
                t.Page.Visible = (i == index)
            end
        end

        for i, t in ipairs(tabs) do
            t.Button.MouseButton1Click:Connect(function()
                selectTab(i)
            end)
        end

        if tabs[defaultIndex] then
            selectTab(defaultIndex)
        elseif tabs[1] then
            selectTab(1)
        end

        local TabsAPI = {}

        function TabsAPI:Select(idx)
            idx = tonumber(idx)
            if idx and tabs[idx] then
                selectTab(idx)
            end
        end

        function TabsAPI:GetSelected()
            return tabs[currentTabIndex]
        end

        function TabsAPI:GetTab(idx)
            idx = tonumber(idx)
            if not idx then return nil end
            local t = tabs[idx]
            return t and t.Section or nil
        end

        return TabsAPI
    end

