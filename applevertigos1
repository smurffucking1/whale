function UILib:CreateWindow(id)
    id = id or ("Window_"..tostring(#self.Windows+1))

    local existing = CoreGui:FindFirstChild("AppleUILib_"..id)
    if existing then existing:Destroy() end

    local gui = Instance.new("ScreenGui")
    gui.Name = "AppleUILib_"..id
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = CoreGui

    local Theme = Themes[CurrentThemeName] or Themes.Dark
    local Style = {
        WindowColor = Theme.WindowColor,
        ButtonColor = Theme.ButtonColor,
        SliderColor = Theme.SliderColor,
    }

    getWindowConfig(id)

    local frame = Instance.new("Frame")
    frame.Name = "Window"
    frame.AnchorPoint = Vector2.new(0,0)
    frame.Size = UDim2.new(0,620,0,420)
    frame.Position = UDim2.new(0.5,-310,0.5,-210)
    frame.BackgroundColor3 = Style.WindowColor
    frame.BorderSizePixel = 0
    frame.Active = true
    frame.ClipsDescendants = true
    frame.Parent = gui
    local fC = Instance.new("UICorner", frame); fC.CornerRadius = UDim.new(0,12)

    local topStrip = Instance.new("Frame")
    topStrip.BackgroundColor3 = Color3.fromRGB(40,40,50)
    topStrip.BorderSizePixel = 0
    topStrip.Size = UDim2.new(1,-16,0,20)
    topStrip.Position = UDim2.new(0,8,0,4)
    topStrip.Parent = frame
    local tsC = Instance.new("UICorner", topStrip); tsC.CornerRadius = UDim.new(1,0)

    local function makeDot(color, x)
        local b = Instance.new("TextButton")
        b.BackgroundColor3 = color
        b.BorderSizePixel = 0
        b.Size = UDim2.new(0,14,0,14)
        b.Position = UDim2.new(0,x,0,3)
        b.Text = ""
        b.AutoButtonColor = false
        b.Parent = topStrip
        local c = Instance.new("UICorner", b); c.CornerRadius = UDim.new(1,0)
        return b
    end

    local closeBtn      = makeDot(Color3.fromRGB(255,95,86),6)
    local minimizeBtn   = makeDot(Color3.fromRGB(255,189,46),24)
    local fullscreenBtn = makeDot(Color3.fromRGB(39,201,63),42)

    local main = Instance.new("Frame")
    main.Name = "MainArea"
    main.BackgroundTransparency = 1
    main.Size = UDim2.new(1,-24,1,-40)
    main.Position = UDim2.new(0,12,0,32)
    main.ClipsDescendants = true
    main.Parent = frame

    local tabsPanel = Instance.new("Frame")
    tabsPanel.Name = "TabsPanel"
    tabsPanel.Size = UDim2.new(0,130,1,0)
    tabsPanel.Position = UDim2.new(0,0,0,0)
    tabsPanel.BackgroundColor3 = Color3.fromRGB(22,22,30)
    tabsPanel.BorderSizePixel = 0
    tabsPanel.ClipsDescendants = true
    tabsPanel.Parent = main
    local tabsCorner = Instance.new("UICorner", tabsPanel); tabsCorner.CornerRadius = UDim.new(0,10)

    local tabsLayout = Instance.new("UIListLayout")
    tabsLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabsLayout.Padding = UDim.new(0,4)
    tabsLayout.Parent = tabsPanel

    local tabsPad = Instance.new("UIPadding")
    tabsPad.PaddingTop = UDim.new(0,6)
    tabsPad.PaddingLeft = UDim.new(0,6)
    tabsPad.PaddingRight = UDim.new(0,6)
    tabsPad.Parent = tabsPanel

    local content = Instance.new("Frame")
    content.Name = "Content"
    content.Size = UDim2.new(1,-140,1,0)
    content.Position = UDim2.new(0,140,0,0)
    content.BackgroundTransparency = 1
    content.ClipsDescendants = true
    content.Parent = main

    local contentLayout = Instance.new("UIListLayout")
    contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
    contentLayout.Padding = UDim.new(0,6)
    contentLayout.Parent = content

    local function newRow(h, parent)
        local p = parent or content
        local r = Instance.new("Frame")
        r.Size = UDim2.new(1,0,0,h or 28)
        r.BackgroundTransparency = 1
        r.ClipsDescendants = true
        r.Parent = p
        return r
    end

    -- registries for recolor
    local sliderFills = {}
    local tabButtons = {}
    local allButtons = {}
    local toggleButtons = {}
    local currentTabIndex = nil

    local function refreshSliders()
        for _, fill in ipairs(sliderFills) do
            if fill and fill.Parent then
                fill.BackgroundColor3 = Style.SliderColor
            end
        end
    end

    local function refreshButtons()
        for _, btn in ipairs(allButtons) do
            if btn and btn.Parent then
                btn.BackgroundColor3 = Style.ButtonColor
            end
        end
        for btn, info in pairs(toggleButtons) do
            if btn and btn.Parent then
                local state = info.GetState()
                if state then
                    btn.BackgroundColor3 = Style.ButtonColor
                else
                    btn.BackgroundColor3 = Color3.fromRGB(60,60,80)
                end
            end
        end
    end

    local function refreshTabButtons()
        for idx, t in ipairs(tabButtons) do
            if t.Button then
                local sel = (idx == currentTabIndex)
                if sel then
                    t.Button.BackgroundColor3 = Style.ButtonColor
                    t.Button.Font = Enum.Font.GothamBold
                    t.Button.TextColor3 = Color3.fromRGB(15,15,20)
                    if t.Stroke then t.Stroke.Transparency = 0.1 end
                else
                    t.Button.BackgroundColor3 = Color3.fromRGB(40,40,50)
                    t.Button.Font = Enum.Font.Gotham
                    t.Button.TextColor3 = Color3.fromRGB(230,230,240)
                    if t.Stroke then t.Stroke.Transparency = 0.7 end
                end
            end
        end
    end

    -- drag, resize, fullscreen

    local dragging = false
    local dragStart, startPos

    local function pointIn(inst,pos)
        local p = inst.AbsolutePosition
        local s = inst.AbsoluteSize
        return pos.X>=p.X and pos.X<=p.X+s.X and pos.Y>=p.Y and pos.Y<=p.Y+s.Y
    end

    topStrip.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mp = UIS:GetMouseLocation()
            if pointIn(closeBtn,mp) or pointIn(minimizeBtn,mp) or pointIn(fullscreenBtn,mp) then
                return
            end
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale,startPos.X.Offset+delta.X,startPos.Y.Scale,startPos.Y.Offset+delta.Y)
        end
    end)

    local resizePad = Instance.new("Frame")
    resizePad.AnchorPoint = Vector2.new(1,1)
    resizePad.Size = UDim2.new(0,22,0,22)
    resizePad.Position = UDim2.new(1,-6,1,-6)
    resizePad.BackgroundColor3 = Color3.fromRGB(60,60,72)
    resizePad.BorderSizePixel = 0
    resizePad.Parent = frame
    local rpC = Instance.new("UICorner", resizePad); rpC.CornerRadius = UDim.new(1,0)
    for i=0,2 do
        local d = Instance.new("Frame")
        d.Size = UDim2.new(0,3,0,3)
        d.Position = UDim2.new(1,-6-i*4,1,-6)
        d.AnchorPoint = Vector2.new(1,1)
        d.BackgroundColor3 = Color3.fromRGB(200,200,210)
        d.BorderSizePixel = 0
        d.Parent = resizePad
    end

    local resizing, resizeStart, startSize = false,nil,nil
    resizePad.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = true
            resizeStart = UIS:GetMouseLocation()
            startSize = frame.Size
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    resizing = false
                end
            end)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if resizing then
            local mp = UIS:GetMouseLocation()
            local delta = mp - resizeStart
            local newW = clampNum(startSize.X.Offset + delta.X, 320, 1100)
            local newH = clampNum(startSize.Y.Offset + delta.Y, 260, 800)
            frame.Size = UDim2.new(0,newW,0,newH)
        end
    end)

    closeBtn.MouseButton1Click:Connect(function() gui:Destroy() end)
    minimizeBtn.MouseButton1Click:Connect(function() frame.Visible = not frame.Visible end)

    local isFullscreen = false
    local savedSize = frame.Size
    local savedPos  = frame.Position

    fullscreenBtn.MouseButton1Click:Connect(function()
        if not isFullscreen then
            savedSize = frame.Size
            savedPos  = frame.Position
            local vpSize = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1280,720)
            local w = math.floor(vpSize.X*0.8)
            local h = math.floor(vpSize.Y*0.8)
            frame.Size = UDim2.new(0,w,0,h)
            frame.Position = UDim2.new(0.5,-w/2,0.5,-h/2)
            isFullscreen = true
        else
            frame.Size = savedSize
            frame.Position = savedPos
            isFullscreen = false
        end
    end)

    UIS.InputBegan:Connect(function(input,gp)
        if gp then return end
        if input.KeyCode == Enum.KeyCode.RightControl then
            frame.Visible = not frame.Visible
        end
    end)

    --======== SECTION FACTORY ========

    local Window = {}
    Window.Frame = frame
    Window.Content = content
    Window.Style = Style
    Window.Id = id

    local function makeSection(parentFrame, sectionExtra)
        local Section = {}
        Section.Parent = parentFrame
        Section.SectionExtra = sectionExtra

        local function newSectionRow(h) return newRow(h, parentFrame) end

        function Section:AddLabel(text)
            local row = newSectionRow(20)
            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(1,-4,1,0)
            lbl.BackgroundTransparency = 1
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 14
            lbl.TextColor3 = Color3.fromRGB(230,230,240)
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Text = text or ""
            lbl.Parent = row
            return lbl
        end

        function Section:AddButton(buttonText, callback)
            local row = newSectionRow(28)
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1,-4,1,0)
            btn.BackgroundColor3 = Style.ButtonColor
            btn.BorderSizePixel = 0
            btn.Font = Enum.Font.GothamBold
            btn.TextSize = 14
            btn.TextColor3 = Color3.fromRGB(230,230,240)
            btn.Text = buttonText or "Button"
            btn.Parent = row
            local bC = Instance.new("UICorner", btn); bC.CornerRadius = UDim.new(0,4)
            table.insert(allButtons, btn)
            btn.MouseButton1Click:Connect(function()
                if callback then callback() end
            end)
            return btn
        end

        function Section:AddToggle(labelText, defaultState, callback)
            local key = controlKey("Toggle", labelText, Section.SectionExtra)
            local saved = getControl(Window.Id, key, "Toggle")
            local state = (typeof(saved) == "boolean") and saved or (defaultState == true)

            local row = newSectionRow(28)

            local lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1
            lbl.Size = UDim2.new(0.6,-4,1,0)
            lbl.Position = UDim2.new(0,0,0,0)
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 14
            lbl.TextColor3 = Color3.fromRGB(230,230,240)
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Text = labelText or "Toggle"
            lbl.Parent = row

            local btn = Instance.new("TextButton")
            btn.AnchorPoint = Vector2.new(1,0)
            btn.Position = UDim2.new(1,0,0,0)
            btn.Size = UDim2.new(0,70,1,0)
            btn.BackgroundColor3 = Style.ButtonColor
            btn.BorderSizePixel = 0
            btn.Font = Enum.Font.GothamBold
            btn.TextSize = 14
            btn.TextColor3 = Color3.fromRGB(230,230,240)
            btn.Parent = row
            local bC = Instance.new("UICorner", btn); bC.CornerRadius = UDim.new(0,4)

            local function refresh()
                if state then
                    btn.BackgroundColor3 = Style.ButtonColor
                    btn.Text = "ON"
                else
                    btn.BackgroundColor3 = Color3.fromRGB(60,60,80)
                    btn.Text = "OFF"
                end
            end

            local function setState(v)
                state = v and true or false
                setControl(Window.Id, key, "Toggle", state)
                refresh()
                if callback then callback(state) end
            end

            toggleButtons[btn] = {GetState = function() return state end}

            btn.MouseButton1Click:Connect(function()
                setState(not state)
            end)

            refresh()

            return {
                Get = function() return state end,
                Set = setState,
            }
        end

        function Section:AddSlider(labelText, minVal, maxVal, defVal, step, callback)
            minVal = minVal or 0
            maxVal = maxVal or 100
            step   = step or 1

            local key = controlKey("Slider", labelText, Section.SectionExtra)
            local saved = getControl(Window.Id, key, "Slider")
            if typeof(saved) == "number" then
                defVal = clampNum(saved, minVal, maxVal)
            else
                defVal = clampNum(defVal or minVal, minVal, maxVal)
            end

            local row = newSectionRow(36)

            local lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1
            lbl.Size = UDim2.new(0.35,-4,0,16)
            lbl.Position = UDim2.new(0,0,0,0)
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 14
            lbl.TextColor3 = Color3.fromRGB(230,230,240)
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Text = labelText or "Slider"
            lbl.Parent = row

            local valueBox = Instance.new("TextBox")
            valueBox.BackgroundTransparency = 1
            valueBox.Size = UDim2.new(0,50,0,16)
            valueBox.Position = UDim2.new(0.35,4,0,0)
            valueBox.Font = Enum.Font.GothamBold
            valueBox.TextSize = 14
            valueBox.TextColor3 = Color3.fromRGB(240,240,250)
            valueBox.TextXAlignment = Enum.TextXAlignment.Left
            valueBox.ClearTextOnFocus = false
            valueBox.Text = tostring(defVal)
            valueBox.Parent = row

            local sliderBg = Instance.new("Frame")
            sliderBg.Size = UDim2.new(0.65,-4,0,8)
            sliderBg.Position = UDim2.new(0,0,0,20)
            sliderBg.BackgroundColor3 = Color3.fromRGB(30,30,40)
            sliderBg.BorderSizePixel = 0
            sliderBg.Parent = row
            local sbC = Instance.new("UICorner", sliderBg); sbC.CornerRadius = UDim.new(0,4)

            local sliderFill = Instance.new("Frame")
            sliderFill.Size = UDim2.new(0,0,1,0)
            sliderFill.Position = UDim2.new(0,0,0,0)
            sliderFill.BackgroundColor3 = Style.SliderColor
            sliderFill.BorderSizePixel = 0
            sliderFill.Parent = sliderBg
            local sfC = Instance.new("UICorner", sliderFill); sfC.CornerRadius = UDim.new(0,4)

            table.insert(sliderFills, sliderFill)

            local sliderDot = Instance.new("Frame")
            sliderDot.Size = UDim2.new(0,12,0,12)
            sliderDot.AnchorPoint = Vector2.new(0.5,0.5)
            sliderDot.Position = UDim2.new(0,0,0.5,0)
            sliderDot.BackgroundColor3 = Color3.fromRGB(230,230,240)
            sliderDot.BorderSizePixel = 0
            sliderDot.Parent = sliderBg
            local sdC = Instance.new("UICorner", sliderDot); sdC.CornerRadius = UDim.new(1,0)

            local val = defVal

            local function update(v)
                v = clampNum(v, minVal, maxVal)
                if step > 0 then
                    v = math.floor((v-minVal)/step+0.5)*step + minVal
                    v = clampNum(v, minVal, maxVal)
                end
                val = v
                local pct = (val-minVal)/(maxVal-minVal)
                sliderFill.Size = UDim2.new(pct,0,1,0)
                sliderDot.Position = UDim2.new(pct,0,0.5,0)
                valueBox.Text = tostring(val)
                setControl(Window.Id, key, "Slider", val)
                if callback then callback(val) end
            end

            update(defVal)

            local draggingSlider = false
            sliderBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = true
                    local mp = UIS:GetMouseLocation()
                    local bgPos = sliderBg.AbsolutePosition
                    local bgSize = sliderBg.AbsoluteSize
                    local relX = math.clamp(mp.X - bgPos.X, 0, bgSize.X)
                    local pct = relX / bgSize.X
                    update(minVal + pct * (maxVal-minVal))
                    input.Changed:Connect(function()
                        if input.UserInputState == Enum.UserInputState.End then
                            draggingSlider = false
                        end
                    end)
                end
            end)

            UIS.InputChanged:Connect(function(input)
                if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                if draggingSlider then
                    local mp = UIS:GetMouseLocation()
                    local bgPos = sliderBg.AbsolutePosition
                    local bgSize = sliderBg.AbsoluteSize
                    local relX = math.clamp(mp.X - bgPos.X, 0, bgSize.X)
                    local pct = relX / bgSize.X
                    update(minVal + pct * (maxVal-minVal))
                end
            end)

            valueBox.FocusLost:Connect(function(enter)
                if not enter then return end
                local num = tonumber(valueBox.Text)
                if not num then
                    valueBox.Text = tostring(val)
                    return
                end
                num = clampNum(num, minVal, maxVal)
                update(num)
            end)

            return {
                Get = function() return val end,
                Set = function(v) update(v) end,
            }
        end

