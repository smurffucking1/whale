    valuePicker.Size = UDim2.new(1,0,0,4)
    valuePicker.AnchorPoint = Vector2.new(0.5,0.5)
    valuePicker.Position = UDim2.new(0.5,0,0,0)
    valuePicker.BackgroundColor3 = Color3.new(1,1,1)
    valuePicker.BorderSizePixel = 0
    valuePicker.Parent = valueBar
    local vpC = Instance.new("UICorner", valuePicker); vpC.CornerRadius = UDim.new(0,2)

    local preview = Instance.new("Frame")
    preview.Size = UDim2.new(0,40,0,40)
    preview.Position = UDim2.new(0,210,0,40)
    preview.BackgroundColor3 = startColor
    preview.BorderSizePixel = 0
    preview.Parent = box
    local prC = Instance.new("UICorner", preview); prC.CornerRadius = UDim.new(0,6)

    local okBtn = Instance.new("TextButton")
    okBtn.Size = UDim2.new(0.5,-8,0,28)
    okBtn.Position = UDim2.new(0,6,1,-34)
    okBtn.BackgroundColor3 = Color3.fromRGB(60,60,80)
    okBtn.BorderSizePixel = 0
    okBtn.Font = Enum.Font.GothamBold
    okBtn.TextSize = 14
    okBtn.TextColor3 = Color3.fromRGB(230,230,240)
    okBtn.Text = "OK"
    okBtn.Parent = box
    local okC = Instance.new("UICorner", okBtn); okC.CornerRadius = UDim.new(0,4)

    local cancelBtn = Instance.new("TextButton")
    cancelBtn.Size = UDim2.new(0.5,-8,0,28)
    cancelBtn.Position = UDim2.new(0.5,2,1,-34)
    cancelBtn.BackgroundColor3 = Color3.fromRGB(50,50,60)
    cancelBtn.BorderSizePixel = 0
    cancelBtn.Font = Enum.Font.Gotham
    cancelBtn.TextSize = 14
    cancelBtn.TextColor3 = Color3.fromRGB(230,230,240)
    cancelBtn.Text = "Cancel"
    cancelBtn.Parent = box
    local caC = Instance.new("UICorner", cancelBtn); caC.CornerRadius = UDim.new(0,4)

    local h,s,v = startColor:ToHSV()

    local function updatePreview()
        preview.BackgroundColor3 = Color3.fromHSV(h,s,v)
    end
    updatePreview()

    local draggingWheel, draggingValue = false,false

    local function updateFromWheel(pos)
        local center = wheel.AbsolutePosition + wheel.AbsoluteSize/2
        local rel = Vector2.new(pos.X-center.X,pos.Y-center.Y)
        local radius = wheel.AbsoluteSize.X/2
        local dist = math.min(rel.Magnitude,radius)
        local angle = math.atan2(rel.Y, rel.X)
        h = (angle/(2*math.pi)) % 1
        s = dist / radius

        local px = radius + math.cos(angle)*dist
        local py = radius + math.sin(angle)*dist
        wheelPicker.Position = UDim2.new(0,px,0,py)
        updatePreview()
    end

    local function updateFromValue(y)
        local bp = valueBar.AbsolutePosition
        local bs = valueBar.AbsoluteSize
        local clamped = math.clamp(y, bp.Y, bp.Y+bs.Y)
        local alpha = (clamped - bp.Y)/bs.Y
        v = 1-alpha
        valuePicker.Position = UDim2.new(0.5,0,1-alpha,0)
        updatePreview()
    end

    wheel.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingWheel = true
            updateFromWheel(UIS:GetMouseLocation())
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    draggingWheel = false
                end
            end)
        end
    end)

    valueBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingValue = true
            updateFromValue(UIS:GetMouseLocation().Y)
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    draggingValue = false
                end
            end)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if draggingWheel then
            updateFromWheel(UIS:GetMouseLocation())
        elseif draggingValue then
            updateFromValue(UIS:GetMouseLocation().Y)
        end
    end)

    okBtn.MouseButton1Click:Connect(function()
        if callback then callback(preview.BackgroundColor3) end
        pickerGui:Destroy()
    end)

    cancelBtn.MouseButton1Click:Connect(function()
        pickerGui:Destroy()
    end)
end

--================ UTIL ================

local function clampNum(v, mn, mx)
    return (v < mn and mn) or (v > mx and mx) or v
end

local function controlKey(kind, label, extra)
    local base = (label or kind):gsub("%s+","_")
    if extra then base = base.."_"..extra end
    return kind..":"..base
end

