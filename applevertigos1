-- Apple-style UI Library (NO internal Settings tab)
-- - Side tabs (vertical)
-- - Sliders, toggles, textboxes, buttons, dropdowns, color pickers
-- - Themes (Dark, OLED) + custom themes saved to APPLE_REC/themes.json
-- - Autosave of all control values + active theme to APPLE_REC/config.json
-- - Live recolor of sliders, buttons, tab buttons when colors/themes change
-- - Dropdowns support SetOptions/Rebuild
-- - Sliders have a text input that controls the slider
-- - Fixed fullscreen button
-- - GetTab(1..n) maps to your tabs (no hidden indices)

local UIS         = game:GetService("UserInputService")
local CoreGui     = game:GetService("CoreGui")
local HttpService = game:GetService("HttpService")

local UILib = {}
UILib.__index = UILib
UILib.Windows = {}

--================ FS + THEME/CONFIG =================

local ROOT_FOLDER = "APPLE_REC"
local THEMES_FILE = ROOT_FOLDER.."/themes.json"
local CONFIG_FILE = ROOT_FOLDER.."/config.json"

local function fsSupported()
    return isfolder and makefolder and isfile and readfile and writefile
end

local function ensureRoot()
    if fsSupported() and not isfolder(ROOT_FOLDER) then
        makefolder(ROOT_FOLDER)
    end
end

ensureRoot()

local Themes = {
    Dark = {
        WindowColor = Color3.fromRGB(25,25,32),
        ButtonColor = Color3.fromRGB(60,60,80),
        SliderColor = Color3.fromRGB(39,201,63),
    },
    OLED = {
        WindowColor = Color3.new(0,0,0),
        ButtonColor = Color3.fromRGB(35,35,45),
        SliderColor = Color3.fromRGB(0,200,150),
    },
}

local CurrentThemeName = "Dark"

local Config = {
    ThemeName = CurrentThemeName,
    Windows   = {},
}

local function serializeColor(c)
    return {R = c.R, G = c.G, B = c.B}
end

local function deserializeColor(t, fallback)
    if type(t) == "table" and t.R and t.G and t.B then
        return Color3.new(t.R, t.G, t.B)
    end
    return fallback
end

local function loadThemes()
    if not fsSupported() then return end
    ensureRoot()
    if not isfile(THEMES_FILE) then return end

    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(THEMES_FILE))
    end)
    if ok and type(data) == "table" then
        for name, t in pairs(data) do
            if type(t) == "table" and t.WindowColor and t.ButtonColor and t.SliderColor then
                Themes[name] = {
                    WindowColor = deserializeColor(t.WindowColor, Themes.Dark.WindowColor),
                    ButtonColor = deserializeColor(t.ButtonColor, Themes.Dark.ButtonColor),
                    SliderColor = deserializeColor(t.SliderColor, Themes.Dark.SliderColor),
                }
            end
        end
    end
end

local function saveThemes()
    if not fsSupported() then return end
    ensureRoot()
    local out = {}
    for name, t in pairs(Themes) do
        out[name] = {
            WindowColor = serializeColor(t.WindowColor),
            ButtonColor = serializeColor(t.ButtonColor),
            SliderColor = serializeColor(t.SliderColor),
        }
    end
    local ok, encoded = pcall(function()
        return HttpService:JSONEncode(out)
    end)
    if ok then
        writefile(THEMES_FILE, encoded)
    end
end

local function loadConfig()
    if not fsSupported() then return end
    ensureRoot()
    if not isfile(CONFIG_FILE) then return end

    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FILE))
    end)
    if ok and type(data) == "table" then
        Config = data
        if Config.ThemeName and Themes[Config.ThemeName] then
            CurrentThemeName = Config.ThemeName
        end
    end
end

local function saveConfig()
    if not fsSupported() then return end
    ensureRoot()
    Config.ThemeName = CurrentThemeName
    local ok, encoded = pcall(function()
        return HttpService:JSONEncode(Config)
    end)
    if ok then
        writefile(CONFIG_FILE, encoded)
    end
end

local function getWindowConfig(winId)
    Config.Windows[winId] = Config.Windows[winId] or {Controls = {}}
    return Config.Windows[winId]
end

local function setControl(winId, key, ctype, value)
    local w = getWindowConfig(winId)
    w.Controls[key] = {Type = ctype, Value = value}
    saveConfig()
end

local function getControl(winId, key, expectedType)
    local w = Config.Windows[winId]
    if not w or not w.Controls or not w.Controls[key] then
        return nil
    end
    local c = w.Controls[key]
    if expectedType and c.Type ~= expectedType then return nil end
    return c.Value
end

loadThemes()
loadConfig()

