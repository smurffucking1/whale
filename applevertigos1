        function Section:AddDropdown(labelText, options, defIndex, callback)
            options = options or {}
            defIndex = defIndex or 1

            local key = controlKey("Dropdown", labelText, Section.SectionExtra)
            local saved = getControl(Window.Id, key, "Dropdown")
            if typeof(saved) == "number" and options[saved] then
                defIndex = saved
            end

            local row = newSectionRow(28)
            row.ClipsDescendants = true
            local baseHeight = 28
            local ddVisible = false
            local ddHeight = 0

            local lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1
            lbl.Size = UDim2.new(0.35,-4,0,baseHeight)
            lbl.Position = UDim2.new(0,0,0,0)
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 14
            lbl.TextColor3 = Color3.fromRGB(230,230,240)
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Text = labelText or "Dropdown"
            lbl.Parent = row

            local btn = Instance.new("TextButton")
            btn.AnchorPoint = Vector2.new(1,0)
            btn.Position = UDim2.new(1,0,0,0)
            btn.Size = UDim2.new(0.65,0,0,baseHeight)
            btn.BackgroundColor3 = Color3.fromRGB(40,40,50)
            btn.BorderSizePixel = 0
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 14
            btn.TextColor3 = Color3.fromRGB(240,240,250)
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.Text = options[defIndex] or "None"
            btn.Parent = row
            local bC2 = Instance.new("UICorner", btn); bC2.CornerRadius = UDim.new(0,4)

            local dd = Instance.new("Frame")
            dd.BackgroundColor3 = Color3.fromRGB(30,30,40)
            dd.BorderSizePixel = 0
            dd.Size = UDim2.new(1,0,0,0)
            dd.Position = UDim2.new(0,0,0,baseHeight)
            dd.Visible = false
            dd.Parent = row
            local dC2 = Instance.new("UICorner", dd); dC2.CornerRadius = UDim.new(0,4)

            local ddLayout = Instance.new("UIListLayout")
            ddLayout.SortOrder = Enum.SortOrder.LayoutOrder
            ddLayout.Padding = UDim.new(0,2)
            ddLayout.Parent = dd

            local selectedIndex = defIndex

            local function setRowHeight()
                if ddVisible then
                    row.Size = UDim2.new(1,0,0,baseHeight + ddHeight + 4)
                else
                    row.Size = UDim2.new(1,0,0,baseHeight)
                end
            end

            local function setSel(i)
                selectedIndex = i
                btn.Text = options[i] or "None"
                setControl(Window.Id, key, "Dropdown", i)
                if callback then callback(options[i], i) end
            end

            local function rebuild()
                for _,child in ipairs(dd:GetChildren()) do
                    if child:IsA("TextButton") then child:Destroy() end
                end
                local count = 0
                for i, opt in ipairs(options) do
                    count += 1
                    local o = Instance.new("TextButton")
                    o.Size = UDim2.new(1,-8,0,20)
                    o.Position = UDim2.new(0,4,0,0)
                    o.BackgroundColor3 = Color3.fromRGB(40,40,50)
                    o.BorderSizePixel = 0
                    o.Font = Enum.Font.Gotham
                    o.TextSize = 13
                    o.TextColor3 = Color3.fromRGB(230,230,240)
                    o.TextXAlignment = Enum.TextXAlignment.Left
                    o.Text = tostring(opt)
                    o.Parent = dd
                    o.MouseButton1Click:Connect(function()
                        setSel(i)
                        ddVisible = false
                        dd.Visible = false
                        setRowHeight()
                    end)
                end
                ddHeight = math.max(1,count)*22
                dd.Size = UDim2.new(1,0,0,ddHeight)
                if ddVisible then setRowHeight() end
            end

            rebuild()
            setSel(defIndex)

            btn.MouseButton1Click:Connect(function()
                ddVisible = not ddVisible
                dd.Visible = ddVisible
                setRowHeight()
            end)

            return {
                Get = function()
                    return options[selectedIndex], selectedIndex
                end,
                Set = function(i)
                    if options[i] then
                        setSel(i)
                    end
                end,
                Rebuild = function()
                    rebuild()
                end,
                SetOptions = function(newOptions, newIndex)
                    options = newOptions or {}
                    selectedIndex = 1
                    if typeof(newIndex) == "number" and options[newIndex] then
                        selectedIndex = newIndex
                    end
                    rebuild()
                    setSel(selectedIndex)
                end,
            }
        end

        return Section
    end

